# ============================================================
# AI servisi yapılandırması — kopyalayıp .env olarak kaydedin
# ============================================================

# ---- ZORUNLU ----
PORT=8000
BACKEND_ORIGIN=http://localhost:4000

# ---- OPSİYONEL (dış servisler — yoksa sezgisel/fallback çalışır) ----
# Hava durumu (gecikme/risk tahminini gerçek veriyle beslemek için)
# Ücretsiz: https://openweathermap.org/api
WEATHER_API_KEY=

# LLM ile doğal dil gerekçe (opsiyonel) — https://console.anthropic.com
ANTHROPIC_API_KEY=
