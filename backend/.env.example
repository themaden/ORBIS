# ============================================================
# Backend yapılandırması — kopyalayıp .env olarak kaydedin
# ============================================================

# ---- ZORUNLU (dış API gerektirmez, kendin üretirsin) ----
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
AI_SERVICE_URL=http://localhost:8000

# PostgreSQL bağlantısı (Docker ya da yerel kurulum)
DATABASE_URL=postgresql://orbis:orbis@localhost:5432/orbis

# JWT imzalama anahtarı — uzun, rastgele bir değer üret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=degistir-uzun-rastgele-bir-deger

# ---- OPSİYONEL (dış servisler — yoksa fallback çalışır) ----
# Hava durumu (risk endeksini gerçek veriyle beslemek için)
# Ücretsiz: https://openweathermap.org/api  -> API key
WEATHER_API_KEY=

# LLM ile doğal dil "öneri gerekçesi" üretmek için (opsiyonel)
# https://console.anthropic.com  (Claude API)
ANTHROPIC_API_KEY=
